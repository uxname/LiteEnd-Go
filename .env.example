# Application settings
PORT=4000
# Comma-separated allowed origins. Include the SPA origin (e.g. http://localhost:3000)
# so the browser frontend can call /graphql and /upload.
CORS_ORIGIN=http://localhost:3000,http://localhost:4000
LOG_LEVEL=info

# Database configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=postgres

# Database backup tool
BACKUP_DIR=./data/database_backups
# Interval between backups, Go duration string (e.g. 24h, 1h30m)
BACKUP_INTERVAL=24h
BACKUP_ROTATION=5
# plain | custom
BACKUP_FORMAT=plain
BACKUP_COMPRESS=true

# Database browser (pgweb — zero-config, Prisma Studio analog)
DB_STUDIO_PORT=5100

# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis
# Redis browser (RedisInsight — pre-configures the connection via RI_REDIS_*)
REDIS_STUDIO_PORT=5200

# Asynqmon queue dashboard (Bull Board analog) — host port
ASYNQMON_PORT=5300

# Admin dashboards auth. ALL dashboards (pgweb, RedisInsight, Asynqmon) sit
# behind a Basic-Auth proxy, and the app's dev pages (/dev, /playground,
# /swagger) require the same credentials — no anonymous access.
ADMIN_USER=admin
ADMIN_PASSWORD=admin
# bcrypt hash of ADMIN_PASSWORD for the Caddy auth proxy (default = "admin").
# Regenerate: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'pass'
# IMPORTANT: escape every $ as $$ so docker compose does not interpolate it.
ADMIN_PASSWORD_HASH=$$2a$$14$$HAt9aLO.T.57BDK8puAjf.H59sFkLvkqhxCtU4sZZgyHiJfHjJATW

# OIDC Configuration
# OIDC_AUDIENCE must match the `aud` claim of the token the SPA sends.
# Recommended (OAuth2-correct): register an API resource in Logto and send the
# access_token issued for it — then set OIDC_AUDIENCE to that resource indicator
# (e.g. http://localhost:4000) and point ISSUER/JWKS at your Logto endpoint:
#   OIDC_ISSUER=https://auth.uxna.me/oidc
#   OIDC_JWKS_URI=https://auth.uxna.me/oidc/jwks
#   OIDC_AUDIENCE=http://localhost:4000   # the Logto API resource identifier
#   OIDC_MOCK_ENABLED=false
OIDC_ISSUER=http://localhost:3001/oidc
# App ID / Client ID (or API resource indicator — see note above)
OIDC_AUDIENCE=your-client-id
OIDC_JWKS_URI=http://localhost:3001/oidc/jwks

# Development mock OIDC user
# Set to "true" to bypass OIDC and use a hardcoded user with ADMIN and USER roles.
# WARNING: This should never be enabled in production.
OIDC_MOCK_ENABLED=true
